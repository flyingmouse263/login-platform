# =============================================================================
# 用户管理系统 - 环境变量配置文件
# =============================================================================
# 使用方法：
#   1. 复制此文件为 .env： cp .env.example .env
#   2. 修改 .env 中的密码为安全值
#   3. 启动时自动加载
#
# 生产环境建议通过系统环境变量或密钥管理服务注入
# =============================================================================

# 必填 - Flask 应用密钥（用于 session 签名，请使用复杂随机字符串）
SECRET_KEY=your-secure-key-minimum-32-chars-here

# 必填 - 管理员 admin 的密码
ADMIN_PWD=admin123

# 必填 - 普通用户 alice 的密码
ALICE_PWD=alice2025

# 可选 - 是否开启 Flask debug 模式（生产环境请留空或设为 false）
# FLASK_DEBUG=false

# 可选 - 是否启用 HTTPS（开启后 session cookie 将添加 Secure 标志）
# ENABLE_HTTPS=false
